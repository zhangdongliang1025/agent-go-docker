#!/usr/bin/env bash

set -e

# =============================================================================
# dev-go - Development Environment Launcher for Claude Code
#
# Provides commands to launch Claude Code in Docker containers with:
# - Multiple JDK versions (8, 11, 17, 21, 25)
# - Full development stack (Go, Rust, Python, Node.js)
# - Web terminal (ttyd) and session persistence (shpool)
# =============================================================================

# ===== Configuration =====
readonly VERSION="2.0.0"
readonly IMAGE_REGISTRY="${AGENT_IMAGE_REGISTRY:-ghcr.io/mark0725/agent-go-docker}"
readonly IMAGE="${IMAGE_REGISTRY}:latest"

AGENT_ID="${AGENT_ID:-default}"
PROJECT_ID="${PROJECT_ID:-$(pwd | sed 's#/#_#g')}"

# Data mount point (default /data)
DATA_MOUNT="${DATA_MOUNT:-/data}"

CLAUDE_HOME="${CLAUDE_HOME:-${HOME}/.claude}"
AGENTS_HOME="${AGENTS_HOME:-${HOME}/.agents}"
AGENTS_HUB="${AGENTS_HUB:-${HOME}/.agents-hub}"

LOCAL_BIN="${LOCAL_BIN:-${HOME}/.local/bin}"
TTY_PORT="${TTY_PORT:-7681}"

SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
SCRIPT_NAME="$(basename "$0")"
DOCKER_SOCK="${DOCKER_SOCK:-/var/run/docker.sock}"

REMAINING_ARGS=()

# ===== Usage =====
usage() {
    cat <<EOF
dev-go v${VERSION} - Development Environment Launcher

Usage: dev-go <command> [options]
       (or invoke via symlinks: dev-cc, dev-cc-web, dev-cc-tmux)

Commands:
  dev-cc         Start claude in interactive CLI mode (default)
  dev-cc-web     Start claude with ttyd web terminal + shpool session (background)
  dev-cc-tmux    Start claude inside a shpool session
  add            Create symlinks for dev commands in a directory (default: ~/.local/bin)

Options:
  -p <path>      Project path to mount (default: current directory)
  --data <path>  Data mount point inside container (default: /data)
  --java8        Use JDK 8
  --java11       Use JDK 11
  --java17       Use JDK 17 (default)
  --java21       Use JDK 21
  --java25       Use JDK 25
  -h, --help     Show this help
  -v, --version  Show version

Examples:
  dev-cc                          # Start with current directory
  dev-cc -p ~/projects/myapp      # Start with specific project
  dev-cc --java21                 # Use JDK 21
  dev-cc -p ~/projects/myapp --java11  # Combined options

Environment variables:
  AGENT_IMAGE_REGISTRY  Docker image registry (default: ghcr.io/mark0725/agent-go-docker)
  AGENT_ID              Agent ID (default: default)
  DATA_MOUNT            Data mount point inside container (default: /data)
  CLAUDE_HOME           Claude config directory (default: ~/.claude)
  AGENTS_HOME           Agents data directory (default: ~/.agents)
  AGENTS_HUB            Agents hub directory (default: ~/.agents-hub)
  LOCAL_BIN             Directory for symlinks (default: ~/.local/bin)
  TTY_PORT              Port for ttyd web server (default: 7681)
EOF
    exit 0
}

version() {
    echo "dev-go v${VERSION}"
    echo "Image: ${IMAGE}"
    exit 0
}

# ===== Error handling =====
error() {
    echo "Error: $1" >&2
    exit 1
}

warn() {
    echo "Warning: $1" >&2
}

# ===== Parse options =====
parse_global_options() {
    REMAINING_ARGS=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -p|--path)
                if [ -z "${2:-}" ]; then
                    error "Option $1 requires a value"
                fi
                PROJECT_HOME="$2"
                shift 2
                ;;
            --data)
                if [ -z "${2:-}" ]; then
                    error "Option $1 requires a value"
                fi
                DATA_MOUNT="$2"
                shift 2
                ;;
            --java8|--java11|--java17|--java21|--java25)
                JDK_VERSION="${1#--java}"
                shift
                ;;
            -h|--help)
                usage
                ;;
            -v|--version)
                version
                ;;
            --)
                shift
                break
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                break
                ;;
        esac
    done

    while [ $# -gt 0 ]; do
        REMAINING_ARGS+=("$1")
        shift
    done
}

# ===== Validate prerequisites =====
validate() {
    if ! command -v docker &> /dev/null; then
        error "Docker is not installed or not in PATH"
    fi

    if ! docker info &> /dev/null; then
        error "Docker daemon is not running or not accessible"
    fi

    # Validate project path
    if [ -n "${PROJECT_HOME:-}" ] && [ ! -d "$PROJECT_HOME" ]; then
        error "Project path does not exist: $PROJECT_HOME"
    fi

    # Ensure required directories exist
    mkdir -p "$CLAUDE_HOME" "$AGENTS_HOME" "$AGENTS_HUB"
}

# ===== Common Docker args =====
append_common_docker_args() {
    local -n _args=$1

    _args+=(
        --user 0
        -e "HOST_UID=$(id -u)"
        -e "HOST_GID=$(id -g)"
        -e "TZ=${TZ:-:/etc/localtime}"
        -e "HOME=/home/node"
        -e "XDG_RUNTIME_DIR=/tmp/runtime-node"
        -e "AGENT_ID=${AGENT_ID}"
        -e "DATA_MOUNT=${DATA_MOUNT}"
    )

    # Pass through auth tokens
    [ -n "${ANTHROPIC_AUTH_TOKEN:-}" ] && _args+=(-e "ANTHROPIC_AUTH_TOKEN=${ANTHROPIC_AUTH_TOKEN}")
    [ -n "${ANTHROPIC_BASE_URL:-}" ] && _args+=(-e "ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL}")
    [ -n "${API_TIMEOUT_MS:-}" ] && _args+=(-e "API_TIMEOUT_MS=${API_TIMEOUT_MS}")
    [ -n "${PROXY_URL:-}" ] && _args+=(-e "PROXY_URL=${PROXY_URL}")
    [ -n "${HTTP_PROXY:-}" ] && _args+=(-e "HTTP_PROXY=${HTTP_PROXY}")
    [ -n "${HTTPS_PROXY:-}" ] && _args+=(-e "HTTPS_PROXY=${HTTPS_PROXY}")

    # JDK version selection
    if [ -n "${JDK_VERSION:-}" ]; then
        _args+=(-e "JDK_VERSION=${JDK_VERSION}")
    fi

    # Mount volumes
    _args+=(
        -v "node_home:/home/node"
        -v "/etc/localtime:/etc/localtime:ro"
        -v "${DOCKER_SOCK}:/var/run/docker.sock"
        -v "${PROJECT_HOME}:${DATA_MOUNT}"
        -v "${CLAUDE_HOME}:/home/node/.claude"
        -v "${AGENTS_HOME}:/home/node/.agents"
        -v "${AGENTS_HUB}:/home/node/.agents-hub"
    )

    # Mount local Maven settings and repository
    if [ -f "${HOME}/.m2/settings.xml" ]; then
        _args+=(-v "${HOME}/.m2/settings.xml:/home/node/.m2/settings.xml:ro")
    fi
    if [ -d "${HOME}/.m2/repository" ]; then
        _args+=(-v "${HOME}/.m2/repository:/home/node/.m2/repository")
    fi

    _args+=(-w "${DATA_MOUNT}")
}

# ===== Run Docker =====
run_docker() {
    local docker_args=(run -it --rm --network=host)
    append_common_docker_args docker_args
    docker "${docker_args[@]}" "$IMAGE" "$@"
}

run_docker_detached() {
    local docker_args=(run -d --rm --network=host)
    [ -n "${CONTAINER_NAME:-}" ] && docker_args+=(--name "$CONTAINER_NAME")
    append_common_docker_args docker_args
    docker "${docker_args[@]}" "$IMAGE" "$@"
}

build_claude_cmd() {
    local claude_cmd
    printf -v claude_cmd '%q ' claude "$@"
    claude_cmd="${claude_cmd% }"
    printf '%s' "$claude_cmd"
}

# ===== Commands =====
cmd_dev_cc() {
    run_docker claude "$@"
}

cmd_dev_cc_tmux() {
    local claude_cmd
    local escaped_claude_cmd
    claude_cmd="$(build_claude_cmd "$@")"
    printf -v escaped_claude_cmd '%q' "$claude_cmd"
    run_docker bash -lc "export CLAUDE_CMD=${escaped_claude_cmd}; mkdir -p \"\$XDG_RUNTIME_DIR\" && chmod 700 \"\$XDG_RUNTIME_DIR\" && exec shpool attach -f -c \"\$CLAUDE_CMD\" claude"
}

cmd_dev_cc_web() {
    local claude_cmd
    local wrapped_claude_cmd
    local escaped_claude_cmd
    local escaped_workspace
    local wrapper
    local container_id
    local container_name

    container_name="${CONTAINER_NAME:-dev-cc-web-$(date +%s)}"
    CONTAINER_NAME="$container_name"

    claude_cmd="$(build_claude_cmd "$@")"
    wrapped_claude_cmd="bash -lc $(printf '%q' ". /tmp/agent-env.sh && exec $claude_cmd")"
    printf -v escaped_claude_cmd '%q' "$wrapped_claude_cmd"
    printf -v escaped_workspace '%q' "$DATA_MOUNT"
    wrapper="/tmp/agent-cc-web-shpool"

    container_id="$(run_docker_detached bash -lc "export CLAUDE_CMD=${escaped_claude_cmd}; export AGENT_WORKSPACE=${escaped_workspace}; export TERM=\"\${TERM:-xterm-256color}\"; export COLORTERM=\"\${COLORTERM:-truecolor}\"; export FORCE_COLOR=\"\${FORCE_COLOR:-3}\"; mkdir -p \"\$XDG_RUNTIME_DIR\" && chmod 700 \"\$XDG_RUNTIME_DIR\" && (umask 077; export -p > /tmp/agent-env.sh) && shpool attach -b -f --dir \"\$AGENT_WORKSPACE\" -c \"\$CLAUDE_CMD\" claude && for i in \$(seq 1 50); do shpool list >/dev/null 2>&1 && break; sleep 0.1; done && printf '%s\\n' '#!/bin/bash' 'exec shpool attach -f claude' > ${wrapper} && chmod +x ${wrapper} && exec /usr/local/bin/ttyd -p ${TTY_PORT} -W ${wrapper}")"
    echo "${container_id}"
    echo "dev-cc-web started: http://localhost:${TTY_PORT}"
    echo "container name: ${container_name}"
}

cmd_add() {
    local target_dir="${1:-${LOCAL_BIN}}"
    local applet
    local link_path

    mkdir -p "${target_dir}"

    echo "Creating symlinks in: ${target_dir}"
    echo "Source: ${SCRIPT_PATH}"
    echo

    for applet in dev-cc dev-cc-web dev-cc-tmux; do
        link_path="${target_dir}/${applet}"
        if [ -L "${link_path}" ]; then
            rm "${link_path}"
            echo "  Updated: ${link_path}"
        elif [ -e "${link_path}" ]; then
            echo "  Skip (exists, not symlink): ${link_path}"
            continue
        else
            echo "  Created: ${link_path}"
        fi
        ln -s "${SCRIPT_PATH}" "${link_path}"
    done

    echo
    echo "Done! Add to PATH:"
    echo "  export PATH=\"${target_dir}:\$PATH\""
}

run_named_command() {
    local subcmd="$1"
    shift || true

    case "$subcmd" in
        dev-cc)
            parse_global_options "$@"
            validate
            cmd_dev_cc "${REMAINING_ARGS[@]}"
            ;;
        dev-cc-web)
            parse_global_options "$@"
            validate
            cmd_dev_cc_web "${REMAINING_ARGS[@]}"
            ;;
        dev-cc-tmux)
            parse_global_options "$@"
            validate
            cmd_dev_cc_tmux "${REMAINING_ARGS[@]}"
            ;;
        add)
            cmd_add "$@"
            ;;
        -h|--help|help)
            usage
            ;;
        -v|--version|version)
            version
            ;;
        *)
            error "Unknown command: ${subcmd}"
            ;;
    esac
}

# ===== Main =====
if [ "$SCRIPT_NAME" = "dev-go" ]; then
    run_named_command "${1:-dev-cc}" "${@:2}"
    exit
fi

case "$SCRIPT_NAME" in
    dev-cc|dev-cc-web|dev-cc-tmux)
        run_named_command "$SCRIPT_NAME" "$@"
        ;;
    add)
        cmd_add "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    -v|--version|version)
        version
        ;;
    *)
        error "Unknown command: $SCRIPT_NAME"
        ;;
esac
